<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#FFFFFF"
    android:padding="4dp">

    <!-- Input container -->
    <LinearLayout
        android:id="@+id/inputContainer"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:orientation="horizontal"
        android:visibility="gone"
        android:paddingHorizontal="8dp"
        android:gravity="center_vertical">

        <EditText
            android:id="@+id/pasteField"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:hint="Paste conversation..."
            android:textSize="14sp"
            android:background="@android:drawable/edit_text"
            android:paddingHorizontal="8dp"
            android:singleLine="true"
            android:importantForAutofill="no"
            android:contentDescription="Paste conversation text here" />

        <Button
            android:id="@+id/readContextBtn"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:text="Read"
            android:textSize="12sp"
            android:layout_marginStart="4dp"
            android:contentDescription="Read text from current field" />

        <Button
            android:id="@+id/suggestBtn"
            android:layout_width="80dp"
            android:layout_height="32dp"
            android:text="Suggest"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:layout_marginStart="4dp"
            android:contentDescription="Get text suggestions" />

        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:visibility="gone"
            android:layout_marginStart="4dp" />
    </LinearLayout>

    <!-- Error container -->
    <LinearLayout
        android:id="@+id/errorContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:visibility="gone"
        android:paddingHorizontal="8dp"
        android:paddingVertical="4dp"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/errorText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="#EF4444"
            android:textSize="12sp" />

        <Button
            android:id="@+id/retryBtn"
            android:layout_width="wrap_content"
            android:layout_height="28dp"
            android:text="Retry"
            android:textSize="11sp" />
    </LinearLayout>

    <!-- Suggestion bar -->
    <HorizontalScrollView
        android:id="@+id/suggestionScroll"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:visibility="gone"
        android:scrollbars="none">

        <LinearLayout
            android:id="@+id/suggestionBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="8dp"
            android:paddingVertical="4dp" />
    </HorizontalScrollView>

    <!-- Toggle row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="36dp"
        android:orientation="horizontal"
        android:paddingHorizontal="8dp"
        android:gravity="center_vertical">

        <Button
            android:id="@+id/toggleBtn"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:text="TC"
            android:textColor="#FFFFFF"
            android:textSize="10sp"
            android:contentDescription="Toggle TextCoach input" />
    </LinearLayout>
</LinearLayout>
